--- !u!114 &5645320479974217264
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5116713213507536252}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a997a8c12536342f6bc24c4fbfd248e8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  battleName: "Xe t\u0103ng 390 h\xFAc \u0111\u1ED5 c\u1ED5ng Dinh \u0110\u1ED9c
    L\u1EADp"
  description: "\u0110\xEAm 29 r\u1EA1ng s\xE1ng 30/4/1975, theo m\u1EC7nh l\u1EC7nh
    c\u1EE7a B\u1ED9 T\u01B0 l\u1EC7nh chi\u1EBFn d\u1ECBch, c\xE1c binh \u0111o\xE0n
    ch\u1EE7 l\u1EF1c c\u1EE7a Qu\xE2n Gi\u1EA3i ph\xF3ng \u0111\u1ED3ng lo\u1EA1t
    ti\u1EBFn c\xF4ng v\xE0o n\u1ED9i \u0111\xF4 S\xE0i G\xF2n, \u0111\xE1nh chi\u1EBFm
    c\xE1c m\u1EE5c ti\xEAu then ch\u1ED1t. Ph\xE1o binh t\u1EEB c\xE1c h\u01B0\u1EDBng
    Nh\u01A1n Tr\u1EA1ch, C\u1EE7 Chi, H\xF3c M\xF4n b\u1EAFn v\xE0o s\xE2n bay T\xE2n
    S\u01A1n Nh\u1EA5t v\xE0 B\u1ED9 T\u1ED5ng tham m\u01B0u qu\xE2n \u0111\u1ED9i
    S\xE0i G\xF2n, l\xE0m t\xEA li\u1EC7t s\xE2n bay v\xE0 t\u1EA1o \u0111i\u1EC1u
    ki\u1EC7n cho c\xE1c m\u0169i ti\u1EBFn c\xF4ng th\u1ECDc s\xE2u.\n\nTr\xEAn
    h\u01B0\u1EDBng T\xE2y B\u1EAFc, Qu\xE2n \u0111o\xE0n 3 ti\u1EBFn c\xF4ng s\xE2n
    bay T\xE2n S\u01A1n Nh\u1EA5t v\xE0 B\u1ED9 T\u1ED5ng tham m\u01B0u. \u0110\u1EBFn
    tr\u01B0a 30/4, S\u01B0 \u0111o\xE0n 10 l\xE0m ch\u1EE7 s\xE2n bay T\xE2n S\u01A1n
    Nh\u1EA5t v\xE0 B\u1ED9 T\u1ED5ng tham m\u01B0u qu\xE2n \u0111\u1ED9i S\xE0i
    G\xF2n. Tr\xEAn h\u01B0\u1EDBng B\u1EAFc, Qu\xE2n \u0111o\xE0n 1 \u0111\xE1nh
    chi\u1EBFm c\xE1c v\u1ECB tr\xED nh\u01B0 Lai Kh\xEA, Ph\xFA L\u1EE3i, B\xECnh
    D\u01B0\u01A1ng, L\xE1i Thi\xEAu, c\u1EA7u V\u0129nh B\xECnh, c\u1EA7u B\xECnh
    Ph\u01B0\u1EDBc, m\u1EDF \u0111\u01B0\u1EDDng ti\u1EBFn v\xE0o n\u1ED9i \u0111\xF4.\n\n\u1EDE
    h\u01B0\u1EDBng T\xE2y Nam, \u0110o\xE0n 232 v\u1EDBi l\u1EF1c l\u01B0\u1EE3ng
    ch\u1EE7 y\u1EBFu l\xE0 S\u01B0 \u0111o\xE0n 9 ti\u1EBFn v\xE0o S\xE0i G\xF2n,
    bao v\xE2y bi\u1EC7t khu Th\u1EE7 \u0111\xF4. T\u01B0\u1EDBng L\xE2m V\u0103n
    Ph\xE1t c\xF9ng thu\u1ED9c c\u1EA5p \u0111\u1EA7u h\xE0ng v\xE0 k\xEAu g\u1ECDi
    binh l\xEDnh h\u1EA1 v\u0169 kh\xED. \u1EDE h\u01B0\u1EDBng \u0110\xF4ng - \u0110\xF4ng
    Nam, Qu\xE2n \u0111o\xE0n 2 v\xE0 Qu\xE2n \u0111o\xE0n 4 ti\u1EBFn c\xF4ng s\u1EDBm
    h\u01A1n c\xE1c h\u01B0\u1EDBng kh\xE1c, \u0111\xE1nh chi\u1EBFm Nh\u01A1n Tr\u1EA1ch,
    C\xE1t L\xE1i, Bi\xEAn H\xF2a, Th\u1EE7 \u0110\u1EE9c, r\u1ED3i v\u01B0\u1EE3t
    c\u1EA7u S\xE0i G\xF2n ti\u1EBFn v\u1EC1 Dinh \u0110\u1ED9c L\u1EADp.\n\nS\u1EF1
    ki\u1EC7n cao tr\xE0o di\u1EC5n ra khi l\u1EF1c l\u01B0\u1EE3ng xe t\u0103ng
    c\u1EE7a Qu\xE2n \u0111o\xE0n 2 ti\u1EBFn v\xE0o Dinh \u0110\u1ED9c L\u1EADp.
    Xe t\u0103ng 843 do B\xF9i Quang Th\u1EADn ch\u1EC9 huy h\xFAc v\xE0o c\u1ED5ng
    nh\u01B0ng b\u1ECB ch\u1EBFt m\xE1y; sau \u0111\xF3 xe t\u0103ng 390 do V\u0169
    \u0110\u0103ng To\xE0n ch\u1EC9 huy lao l\xEAn h\xFAc \u0111\u1ED5 c\u1ED5ng
    ch\xEDnh. \u0110\u1EBFn 11 gi\u1EDD 30 ph\xFAt ng\xE0y 30/4/1975, c\u1EDD Gi\u1EA3i
    ph\xF3ng tung bay tr\xEAn n\xF3c Dinh \u0110\u1ED9c L\u1EADp, b\xE1o hi\u1EC7u
    Chi\u1EBFn d\u1ECBch H\u1ED3 Ch\xED Minh to\xE0n th\u1EAFng.\n\nSau \u0111\xF3,
    T\u1ED5ng th\u1ED1ng ch\xEDnh quy\u1EC1n S\xE0i G\xF2n D\u01B0\u01A1ng V\u0103n
    Minh v\xE0 n\u1ED9i c\xE1c \u0111\u1EA7u h\xE0ng. D\u01B0\u01A1ng V\u0103n Minh
    c\xF9ng V\u0169 V\u0103n M\u1EABu \u0111\u01B0\u1EE3c \u0111\u01B0a sang \u0110\xE0i
    ph\xE1t thanh S\xE0i G\xF2n \u0111\u1EC3 \u0111\u1ECDc tuy\xEAn b\u1ED1 \u0111\u1EA7u
    h\xE0ng kh\xF4ng \u0111i\u1EC1u ki\u1EC7n. C\xF9ng v\u1EDBi c\xE1c m\u0169i ti\u1EBFn
    c\xF4ng qu\xE2n s\u1EF1, nh\xE2n d\xE2n trong n\u1ED9i \u0111\xF4 c\u0169ng n\u1ED5i
    d\u1EADy chi\u1EBFm c\xF4ng s\u1EDF, k\xEAu g\u1ECDi ch\xEDnh quy\u1EC1n S\xE0i
    G\xF2n \u0111\u1EA7u h\xE0ng v\xE0 b\u1EA3o v\u1EC7 c\xE1c c\u01A1 s\u1EDF ch\xEDnh
    tr\u1ECB, kinh t\u1EBF, v\u0103n h\xF3a, x\xE3 h\u1ED9i."
  videoClip: {fileID: 32900000, guid: 1a8c7db971edf40c987032bb9e1f0483, type: 3}
